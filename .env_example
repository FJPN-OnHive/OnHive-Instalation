MONGODB_HOST=<Database Host (localhost)>
MONGODB_PORT=<Database Port (27017)>
MONGODB_USER=<Database User>
MONGODB_PASSWORD=<Database Password>
API_PORT=<Backend Api port (4000)>
APP_PORT=<Frontend App port (4200)>

# Optional - used by docker-compose (defaults: onhive, http://localhost:4000, production)
# MongoDbSettings__DataBase=onhive
# VITE_API_URL=http://localhost:4000
# VITE_ENV=production